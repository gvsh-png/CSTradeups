# Required for accurate pricing (https://steamapis.com — free tier: 500 req/month)
STEAMAPIS_API_KEY=

# Optional: OpenRouter API key for AI trade-up insights (https://openrouter.ai)
OPENROUTER_API_KEY=

# Optional: override the AI model (default: google/gemini-2.5-flash-lite)
OPENROUTER_MODEL=

# --- Steam login + limits (required to gate users) ---
# Free Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Random secret for signing session cookies (e.g. openssl rand -base64 32)
AUTH_SECRET=
# Public site URL (e.g. https://your-domain.com) — required for Steam return_to
APP_URL=
# When true, scans/saves require Steam login. Defaults to true once auth is fully configured.
# AUTH_REQUIRED=true

# Upstash Redis (https://upstash.com) — stores users, quotas, Stripe links
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Stripe Pro subscription (optional until you monetize) ---
STRIPE_SECRET_KEY=
# Recurring Price ID from Stripe Dashboard (Products → Price)
STRIPE_PRICE_ID=
# Webhook signing secret for /api/billing/webhook
STRIPE_WEBHOOK_SECRET=
