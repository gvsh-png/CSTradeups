# Recommended: SteamApis key for accurate bulk Steam Market sale prices (https://steamapis.com)
# Without this, prices come from Skinport + individual Steam lookups (less accurate)
STEAMAPIS_API_KEY=

# Optional: CSFloat API key (https://csfloat.com/developers)
CSFLOAT_API_KEY=

# Optional: OpenRouter API key for AI-powered trade-up insights
OPENROUTER_API_KEY=
