# Required for accurate pricing (https://steamapis.com — free tier: 500 req/month)
STEAMAPIS_API_KEY=

# Optional: OpenRouter API key for AI trade-up insights (https://openrouter.ai)
OPENROUTER_API_KEY=

# Optional: override the AI model (default: google/gemini-2.5-flash-lite)
OPENROUTER_MODEL=

